generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

model ScheduleEvent {
  id              String   @id @default(cuid())
  date            DateTime // The specific date of this event (stored at noon UTC)
  time            String   // Display format: "8:00 AM"
  sortOrder       Int      // Minutes from midnight for chronological ordering
  durationMinutes Int      @default(60)
  title           String
  description     String?
  location        String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([date])
}
