generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

model ScheduleEvent {
  id              String   @id @default(cuid())
  date            DateTime // The specific date of this event (stored at noon UTC)
  time            String   // Display format: "8:00 AM"
  sortOrder       Int      // Minutes from midnight for chronological ordering
  durationMinutes Int      @default(60)
  title           String
  description     String?
  location        String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([date])
}

model SeasonTemplate {
  id          String        @id @default(cuid())
  name        String
  description String
  totalDays   Int
  days        TemplateDay[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model TemplateDay {
  id         String             @id @default(cuid())
  templateId String
  template   SeasonTemplate     @relation(fields: [templateId], references: [id], onDelete: Cascade)
  dayOffset  Int
  label      String
  events     TemplateDayEvent[]

  @@index([templateId])
}

model TemplateDayEvent {
  id              String      @id @default(cuid())
  dayId           String
  day             TemplateDay @relation(fields: [dayId], references: [id], onDelete: Cascade)
  title           String
  time            String      // 24-hr format "08:00"
  durationMinutes Int         @default(60)
  location        String
  description     String?

  @@index([dayId])
}

model CopticDayCache {
  id         String   @id // format: "YYYY-MM-DD"
  date       DateTime @unique
  copticDate String? // e.g., "Baramhat 2, 1742"
  season     String? // e.g., "Great Lent"
  seasonDay  String? // e.g., "Wednesday of the fourth week of Great Lent"
  isFasting  Boolean  @default(false)
  readings   Json? // Reading sections (Prophecies, Pauline, Catholic, Acts, Gospels, Psalms)
  synaxarium Json? // Array of { name, url }
  feasts     Json? // Array of { name, type } from celebrations endpoint
  fetchedAt  DateTime @default(now())

  @@index([date])
}

model LiturgicalEvent {
  id          String   @id @default(cuid())
  date        DateTime
  title       String
  description String?
  eventType   String // "feast", "fast", "majorFeast", "minorFeast", "lordlyFeast"
  source      String   @default("coptic.io")
  createdAt   DateTime @default(now())

  @@unique([date, title])
  @@index([date])
}

model ActivityLog {
  id        String   @id @default(cuid())
  userName  String
  action    String   // "created" | "updated" | "deleted" | "batch_created"
  detail    String   // e.g. "Divine Liturgy on Sun Mar 22"
  count     Int      @default(1) // >1 for batch operations
  createdAt DateTime @default(now())

  @@index([createdAt(sort: Desc)])
  @@index([userName])
}

model UserLastSeen {
  userName   String   @id
  lastSeenAt DateTime
}

model WeeklyService {
  id              String   @id @default(cuid())
  dayOfWeek       Int      // 0=Sunday, 5=Friday, 6=Saturday
  title           String
  time            String   // 24-hr format "08:00"
  durationMinutes Int      @default(60)
  location        String
  description     String?
  enabled         Boolean  @default(true)
  sortOrder       Int      // minutes from midnight, for ordering within the day
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([dayOfWeek])
}

// Singleton row (id = "current") tracking YouTube live status via PubSubHubbub webhook
model LivestreamStatus {
  id        String   @id @default("current")
  isLive    Boolean  @default(false)
  videoId   String?
  title     String?
  thumbnail String?
  viewers   String?
  updatedAt DateTime @updatedAt

  // PubSubHubbub subscription tracking
  subscribedAt    DateTime?
  leaseExpiresAt  DateTime?
}
