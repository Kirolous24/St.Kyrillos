generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

model ScheduleEvent {
  id              String   @id @default(cuid())
  date            DateTime // The specific date of this event (stored at noon UTC)
  time            String   // Display format: "8:00 AM"
  sortOrder       Int      // Minutes from midnight for chronological ordering
  durationMinutes Int      @default(60)
  title           String
  description     String?
  location        String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([date])
}

model SeasonTemplate {
  id          String        @id @default(cuid())
  name        String
  description String
  totalDays   Int
  days        TemplateDay[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model TemplateDay {
  id         String             @id @default(cuid())
  templateId String
  template   SeasonTemplate     @relation(fields: [templateId], references: [id], onDelete: Cascade)
  dayOffset  Int
  label      String
  events     TemplateDayEvent[]

  @@index([templateId])
}

model TemplateDayEvent {
  id              String      @id @default(cuid())
  dayId           String
  day             TemplateDay @relation(fields: [dayId], references: [id], onDelete: Cascade)
  title           String
  time            String      // 24-hr format "08:00"
  durationMinutes Int         @default(60)
  location        String
  description     String?

  @@index([dayId])
}

model CopticDayCache {
  id         String   @id // format: "YYYY-MM-DD"
  date       DateTime @unique
  copticDate String? // e.g., "Baramhat 2, 1742"
  season     String? // e.g., "Great Lent"
  seasonDay  String? // e.g., "Wednesday of the fourth week of Great Lent"
  isFasting  Boolean  @default(false)
  readings   Json? // Reading sections (Prophecies, Pauline, Catholic, Acts, Gospels, Psalms)
  synaxarium Json? // Array of { name, url }
  feasts     Json? // Array of { name, type } from celebrations endpoint
  fetchedAt  DateTime @default(now())

  @@index([date])
}

model LiturgicalEvent {
  id          String   @id @default(cuid())
  date        DateTime
  title       String
  description String?
  eventType   String // "feast", "fast", "majorFeast", "minorFeast", "lordlyFeast"
  source      String   @default("coptic.io")
  createdAt   DateTime @default(now())

  @@unique([date, title])
  @@index([date])
}
